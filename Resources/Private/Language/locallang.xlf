<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
    <file source-language="en" datatype="plaintext" original="messages" product-name="mai_accessibility">
        <body>
            <trans-unit id="module.title">
                <source>Accessibility Analysis</source>
            </trans-unit>
            <trans-unit id="module.description">
                <source>Scan your pages for common accessibility issues including missing alt texts, broken heading hierarchies, invalid ARIA attributes, and non-descriptive link texts.</source>
            </trans-unit>

            <trans-unit id="scope.label">
                <source>Scope</source>
            </trans-unit>
            <trans-unit id="scope.all_pages">
                <source>All pages</source>
            </trans-unit>
            <trans-unit id="scope.apply">
                <source>Apply</source>
            </trans-unit>

            <trans-unit id="action.run_check">
                <source>Run Accessibility Check</source>
            </trans-unit>
            <trans-unit id="action.export_csv">
                <source>Export as CSV</source>
            </trans-unit>
            <trans-unit id="action.back">
                <source>Back to Overview</source>
            </trans-unit>

            <trans-unit id="pages.list.title">
                <source>Pages to be checked</source>
            </trans-unit>
            <trans-unit id="pages.column.title">
                <source>Title</source>
            </trans-unit>
            <trans-unit id="pages.empty">
                <source>No published normal pages found.</source>
            </trans-unit>

            <trans-unit id="check.title">
                <source>Accessibility Check Results</source>
            </trans-unit>
            <trans-unit id="check.total_errors">
                <source>Errors</source>
            </trans-unit>
            <trans-unit id="check.total_warnings">
                <source>Warnings</source>
            </trans-unit>
            <trans-unit id="check.page_heading">
                <source>Page</source>
            </trans-unit>
            <trans-unit id="check.no_issues">
                <source>No accessibility issues found. Great work!</source>
            </trans-unit>

            <trans-unit id="result.column.check">
                <source>Check</source>
            </trans-unit>
            <trans-unit id="result.column.severity">
                <source>Severity</source>
            </trans-unit>
            <trans-unit id="result.column.message">
                <source>Message</source>
            </trans-unit>
            <trans-unit id="result.column.context">
                <source>Context</source>
            </trans-unit>
        </body>
    </file>
